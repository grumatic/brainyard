[88.118821, "o", "│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[2m──────────┼──────────────────────────────────────────────────\u001b[0m                                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mid\u001b[0m       \u001b[2m │ \u001b[0m\u001b[36maudit-bash\u001b[0m                                                                          \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mevent\u001b[0m    \u001b[2m │ \u001b[0m\u001b[36magent.tool-use/post\u001b[0m (non-gated, observer)                                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mmatch\u001b[0m    \u001b[2m │ \u001b[0m\u001b[36m{:tool-name \"bash\"}\u001b[0m                                                                 \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mdoc\u001b[0m      \u001b[2m │ \u001b[0mAppend every bash command to \u001b[36m.brainyard/audit.log\u001b[0m                                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mpersisted\u001b[0m\u001b[2m │ \u001b[0m\u001b[36m.brainyard/hooks/audit-bash.edn\u001b[0m                        "]
[88.118877, "o", "                             \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                 \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mBody\u001b[0m reads the command at \u001b[36m(get-in event [:args :command])\u001b[0m and appends it (plus a newline) to    \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36m.brainyard/audit.log\u001b[0m via \u001b[36mwrite-file … :append true\u001b[0m.                                             \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                 \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mWhen & what it does\u001b[0m                                                                             \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m   • \u001b[1;97mFires:\u001b[0m immediately after \u001b[1;97mevery\u001b[0m \u001b[36mbash\u001b[0m tool call completes, in this project.                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m   • \u001b[1;97mSide effect:\u001b[0m appends the executed command to \u001b[36m.brainyard/audit.log\u001b[0m.     "]
[88.118908, "o", "                     \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                 \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mNotes\u001b[0m                                                                                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m   • Scope is \u001b[1;97mproject-local\u001b[0m — lives with this project's \u001b[36m.brainyard/hooks/\u001b[0m and survives restarts. \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m   • Observer-only: it records the command but cannot block or alter the bash call.              \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m   • To inspect later: \u001b[36mhooks$read :id audit-bash\u001b[0m. To remove: \u001b[36mhooks$delete :id audit-bash\u001b[0m.        \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m└─────────────────────────────────────────────────────────────────────────────────────────"]
