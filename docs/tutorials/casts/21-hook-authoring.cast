[40.244265, "o", "ion\u001b[0m                  \u001b[2m │ \u001b[0m\u001b[36m:agent :exception :phase\u001b[0m                            \u001b[92m│\u001b[0m\u001b[7;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mTasks\u001b[0m \u001b[2m │ \u001b[0m\u001b[36mtask/created\u001b[0m · \u001b[36mtask/completed\u001b[0m    \u001b[2m │ \u001b[0m\u001b[36m:task\u001b[0m                                               \u001b[92m│\u001b[0m\u001b[8;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mTodo\u001b[0m  \u001b[2m │ \u001b[0m\u001b[36mtodo/updated\u001b[0m                     \u001b[2m │ \u001b[0m\u001b[36m:active-slug :agent :todo-list\u001b[0m                      \u001b[92m│\u001b[0m\u001b[9;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[10;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97m🔒 Gated events (NOT available to user hooks in v1)\u001b[0m                                              \u001b[92m│\u001b[0m\u001b[11;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[12;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36magent.ask/finalize\u001b[0m — \u001b[36m:agent :input :result\u001b[0m                                      "]
[40.244293, "o", "             \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36magent.tool-use/pre\u001b[0m — \u001b[36m:agent :args :call-id :depth :tool-name\u001b[0m                                 \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│\u001b[0m These are reserved for block/modify/replace behavior. v1 hooks are \u001b[1;97mobserver-only\u001b[0m (return value   \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m ignored), so gating a tool call isn't supported — but you can observe \u001b[36magent.tool-use/post\u001b[0m to     \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m log/alert instead.                                                                               \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[19;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m───────────────────────────────────────────"]
[40.244302, "o", "─────────────────────────────────────────────────────\u001b[0m \u001b[92m│\u001b[0m\u001b[20;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[21;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mNote:\u001b[0m Hooks live with the \u001b[1;97mcurrent project\u001b[0m (\u001b[36m.brainyard/hooks/\u001b[0m). Want me to author one? Just tell  \u001b[92m│\u001b[0m\u001b[22;1H\u001b[2K\u001b[92m│\u001b[0m me the event, the scope (e.g. only when \u001b[36mbash\u001b[0m runs), and the side effect — I'll draft, dry-run,   \u001b[92m│\u001b[0m\u001b[23;1H\u001b[2K\u001b[92m│\u001b[0m and register it.                                                                                 \u001b[92m│\u001b[0m\u001b[24;1H\u001b[2K\u001b[92m└─────────────────────────────────────────────────────────────────────────────────────"]
