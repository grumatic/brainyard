[40.256613, "o", "                                            \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36magent.ask/finalize\u001b[0m — \u001b[36m:agent :input :result\u001b[0m                                                   \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36magent.tool-use/pre\u001b[0m — \u001b[36m:agent :args :call-id :depth :tool-name\u001b[0m                                 \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m These are reserved for block/modify/replace behavior. v1 hooks are \u001b[1;97mobserver-only\u001b[0m (return value   \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m ignored), so gating a tool call isn't supported — but you can observe \u001b[36magent.tool-use/post\u001b[0m to     \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m│\u001b[0m log/alert instead.                                                                               \u001b[92m│\u001b[0m\u001b[19;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                 "]
