[78.796918, "o", "\u001b[27;1H\r\n\u001b[27;1H\r\n\u001b[92m┌──────────────────────────────────────────────────────────────────────────────────────────────────┐\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97m`defcommand` macro\u001b[0m                                                                               \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mFile:\u001b[0m \u001b[36mcomponents/agent/src/ai/brainyard/agent/core/tool.clj\u001b[0m (line 195)                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mTwo-sentence summary:\u001b[0m                                                                            \u001b[92m│\u001b[0m"]
[78.796927, "o", "\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mdefcommand\u001b[0m is a thin, backwards-compatible wrapper around the core \u001b[36mdeftool\u001b[0m macro that forwards   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m its \u001b[36mcmd-name\u001b[0m, \u001b[36mdescription\u001b[0m, and \u001b[36mcall-fn\u001b[0m arguments while injecting \u001b[36m:type :command\u001b[0m. It registers    \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m the resulting command into the unified \u001b[36m!tool-defs\u001b[0m registry, following the same pattern as its    \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m siblings \u001b[36mdefskill\u001b[0m (\u001b[36m:type :skill\u001b[0m) and \u001b[36mdefagent\u001b[0m (\u001b[36m:type :agent\u001b[0m).                                    \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mDefinition:\u001b[0m                                                                                      \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m(defmacro defcommand\u001b[0m                                                                         "]
