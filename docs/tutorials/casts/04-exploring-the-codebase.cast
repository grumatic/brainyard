[80.084974, "o", "mmary:\u001b[0m                                                                            \u001b[92m│\u001b[0m\u001b[9;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36mdefcommand\u001b[0m is a thin, backwards-compatible wrapper around the core \u001b[36mdeftool\u001b[0m macro that forwards   \u001b[92m│\u001b[0m\u001b[10;1H\u001b[2K\u001b[92m│\u001b[0m its \u001b[36mcmd-name\u001b[0m, \u001b[36mdescription\u001b[0m, and \u001b[36mcall-fn\u001b[0m arguments while injecting \u001b[36m:type :command\u001b[0m. It registers    \u001b[92m│\u001b[0m\u001b[11;1H\u001b[2K\u001b[92m│\u001b[0m the resulting command into the unified \u001b[36m!tool-defs\u001b[0m registry, following the same pattern as its    \u001b[92m│\u001b[0m\u001b[12;1H\u001b[2K\u001b[92m│\u001b[0m siblings \u001b[36mdefskill\u001b[0m (\u001b[36m:type :skill\u001b[0m) and \u001b[36mdefagent\u001b[0m (\u001b[36m:type :agent\u001b[0m).                                    \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mDefinition:\u001b[0m                                                                                      \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│"]
[80.085054, "o", "\u001b[0m \u001b[2m\u001b[36m(defmacro defcommand\u001b[0m                                                                             \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  \"Define a command. Thin wrapper around deftool with :type :command.\"\u001b[0m                           \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  [cmd-name description call-fn & {:as args}]\u001b[0m                                                    \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  `(deftool ~cmd-name ~description ~call-fn ~@(mapcat identity (assoc args :type :command))))\u001b[0m    \u001b[92m│\u001b[0m\u001b[19;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[20;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mCitation:\u001b[0m \u001b[36mfile:components/agent/src/ai/brainyard/agent/core/tool.clj:195\u001b[0m                         \u001b[92m│\u001b[0m\u001b[21;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                  \u001b[92m│\u001b[0m\u001b[22;1H\u001b[2K\u001b[92m│\u001b[0m Saved exploratio"]
