[115.814377, "o", "\u001b[1;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[2;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97m2. What It Returns\u001b[0m                                                                                        \u001b[92m│\u001b[0m\u001b[3;1H\u001b[2K\u001b[92m│\u001b[0m An \u001b[1;97marray with exactly two elements\u001b[0m (destructure it):                                                      \u001b[92m│\u001b[0m\u001b[4;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[5;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mPosition\u001b[0m\u001b[2m │ \u001b[0m\u001b[1;97mName\u001b[0m           \u001b[2m │ \u001b[0m\u001b[1;97mWhat it is\u001b[0m                                                                   \u001b[92m│\u001b[0m\u001b[6;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m─────────┼─────────────────┼────────────────────────────────────────────"]
[115.81442, "o", "──────────────────────────\u001b[0m        \u001b[92m│\u001b[0m\u001b[7;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36m[0]\u001b[0m     \u001b[2m │ \u001b[0m\u001b[1;97mcurrent state\u001b[0m  \u001b[2m │ \u001b[0mThe value for this render                                                    \u001b[92m│\u001b[0m\u001b[8;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36m[1]\u001b[0m     \u001b[2m │ \u001b[0m\u001b[1;97msetter function\u001b[0m\u001b[2m │ \u001b[0mCall it (e.g. \u001b[36msetCount(next)\u001b[0m) to update state and trigger a re-render        \u001b[92m│\u001b[0m\u001b[9;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[10;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[32m│ \u001b[0mThe setter schedules a re-render — never reassign the state variable directly.                          \u001b[92m│\u001b[0m\u001b[11;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[12;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97m3. Tiny Example\u001b[0m                                                            "]
[115.814453, "o", "                               \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36mimport { useState } from 'react';\u001b[0m                                                                         \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m\u001b[0m                                                                                                          \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36mfunction Counter() {\u001b[0m                                                                                      \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  const [count, setCount] = useState(0);\u001b[0m                                                                  \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m\u001b[0m                                                                                                          \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  return (\u001b[0m                                                                                                \u001b[92m│\u001b[0m\u001b[19;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m    <button onClic"]
