[115.865492, "o", "────────────────────┐\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97mReact `useState` Hook\u001b[0m                                                                                     \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[3mFetched via \u001b[36mskill$find-docs\u001b[0m → Context7 (\u001b[36m/reactjs/react.dev\u001b[0m, official React docs).\u001b[0m                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97m1. Signature / Syntax\u001b[0m                                                                                     \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36mimport { useState } from 'react';\u001b[0m                                                                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m\u001b[0m                                                                      "]
[115.865499, "o", "                                    \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36mconst [stateVariable, setStateVariable] = useState(initialState);\u001b[0m                                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • Call it at the \u001b[1;97mtop level\u001b[0m of your component — never inside loops, conditions, or nested functions.     \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • \u001b[36minitialState\u001b[0m is the value used on the first render (any type, or a lazy initializer function).        \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97m2. What It Returns\u001b[0m                                                                                        \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m An \u001b[1;97marray with exactly two elements\u001b[0m (destructure it):                                                      \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                       "]
[115.865526, "o", "    \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97mPosition\u001b[0m\u001b[2m │ \u001b[0m\u001b[1;97mName\u001b[0m           \u001b[2m │ \u001b[0m\u001b[1;97mWhat it is\u001b[0m                                                                   \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m─────────┼─────────────────┼──────────────────────────────────────────────────────────────────────\u001b[0m        \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[36m[0]\u001b[0m     \u001b[2m │ \u001b[0m\u001b[1;97mcurrent state\u001b[0m  \u001b[2m │ \u001b[0mThe value for this render                                                    \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[36m[1]\u001b[0m     \u001b[2m │ \u001b[0m\u001b[1;97msetter function\u001b[0m\u001b[2m │ \u001b[0mCall it (e.g. \u001b[36msetCount(next)\u001b[0m) to update state and trigger a re-render        \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b"]
[115.865557, "o", "[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[32m│ \u001b[0mThe setter schedules a re-render — never reassign the state variable directly.                          \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97m3. Tiny Example\u001b[0m                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36mimport { useState } from 'react';\u001b[0m                                                                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m\u001b[0m                                                                                                          \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36mfunction Counter() {\u001b[0m                                                                                      \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  const [count, setCount] = useState(0);\u001b[0m                                                                  \u001b[92m│\u001b[0m\r\n\u001b[92m│"]
[115.865577, "o", "\u001b[0m \u001b[2m\u001b[36m\u001b[0m                                                                                                          \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  return (\u001b[0m                                                                                                \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m    <button onClick={() => setCount(count + 1)}>\u001b[0m                                                          \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m      You clicked {count} times\u001b[0m                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m    </button>\u001b[0m                                                                                             \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m  );\u001b[0m                                                                                                      \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[2m\u001b[36m}\u001b[0m                                                                                                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b["]
[115.865599, "o", "0m                                                                                                           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97mIn short:\u001b[0m \u001b[36museState(initial)\u001b[0m gives you a \u001b[36m[value, setter]\u001b[0m pair — read \u001b[36mvalue\u001b[0m to render, call \u001b[36msetter(next)\u001b[0m to \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m update and re-render.                                                                                     \u001b[92m│\u001b[0m\r\n\u001b[92m└───────────────────────────────────────────────────────────────────────────────────────────────────────────┘\u001b[0m\r\n\r\n                                                                           \u001b[2m6 calls │ 201,128 tokens │ $0.7411\u001b[0m\r\n"]
