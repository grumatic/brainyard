[272.865036, "o", "\u001b[1;1H\u001b[2K\u001b[92m│\u001b[0m Checked \u001b[36mtask-1\u001b[0m (\u001b[36mhttp-server-8000\u001b[0m) — it's \u001b[1;97mstill running\u001b[0m, but its output log has printed \u001b[1;97mnothing yet\u001b[0m.     \u001b[92m│\u001b[0m\u001b[2;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                         \u001b[92m│\u001b[0m\u001b[3;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mField\u001b[0m       \u001b[2m │ \u001b[0m\u001b[1;97mValue\u001b[0m                                                                                    \u001b[92m│\u001b[0m\u001b[4;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m─────────────┼───────────────────────────────────────────────\u001b[0m                                           \u001b[92m│\u001b[0m\u001b[5;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mStatus\u001b[0m      \u001b[2m │ \u001b[0mrunning (~190s uptime)                                                                   \u001b[92m│\u001b[0m\u001b[6;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mLines logged\u001b[0m\u001b[2m │ \u001b[0m\u001b[36m0\u001b[0m                                   "]
[272.865058, "o", "                                                     \u001b[92m│\u001b[0m\u001b[7;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mLog file\u001b[0m    \u001b[2m │ \u001b[0m\u001b[36m…/demo-site/.brainyard/tasks/task-1/output.log\u001b[0m                                           \u001b[92m│\u001b[0m\u001b[8;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                         \u001b[92m│\u001b[0m\u001b[9;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mWhy it's empty\u001b[0m                                                                                          \u001b[92m│\u001b[0m\u001b[10;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36mpython3 -m http.server\u001b[0m only writes a line each time it \u001b[1;97mserves a request\u001b[0m (e.g. \u001b[36m127.0.0.1 - - [..] \"GET /\u001b[0m \u001b[92m│\u001b[0m\u001b[11;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36mHTTP/1.1\" 200 -\u001b[0m). No request log lines means \u001b[1;97mno one has hit the server yet\u001b[0m.                             \u001b[92m│\u001b[0m\u001b[12;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                         \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97"]
[272.865089, "o", "mTo make it print something\u001b[0m                                                                              \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m   • Open \u001b[1;97mhttp://localhost:8000/\u001b[0m in a browser, or                                                        \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36mcurl http://localhost:8000/\u001b[0m from a terminal                                                         \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                         \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m Then re-check with \u001b[36mtask$detail\u001b[0m → \u001b[36mtask-1\u001b[0m (\u001b[36m:last-n 20\u001b[0m) and you'll see the access log entries.             \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m└──────────────────────────────────────────────────────────────────────────────────────────"]
