[87.042952, "o", "\u001b[1;1H\u001b[2K    \u001b[2m│ \u001b[0m=== PER-FILE COUNTS ===\u001b[2;1H\u001b[2K    \u001b[2m│ \u001b[0mnil\u001b[3;1H\u001b[2K    \u001b[2m└─\u001b[0m\u001b[4;1H\u001b[2K\u001b[2m[\u001b[0m\u001b[1;96m+\u001b[0m\u001b[2m] \u001b[0m\u001b[1;97mIteration 5 / 100\u001b[0m  \u001b[2m(32540 tok)\u001b[0m  \u001b[2m(15.9s)\u001b[0m\u001b[5;1H\u001b[2K\u001b[2m  Think: \u001b[0m\u001b[2mThe rlm$ reduce helpers returned nil fields — probably an arg-shape mismatch with how they're bound \u001b[0m\u001b[6;1H\u001b[2K         \u001b[2min the sandbox. The map results are already in `mapped` (4 strings, one JSON object per line). The \u001b[0m\u001b[7;1H\u001b[2K         \u001b[2mdataset is tiny, so I'll do the reduce manually: split each result by newline, parse-json each \u001b[0m\u001b[8;1H\u001b[2K         \u001b[2mnon-blank line, then use frequencies to count by :category and by :file. This avoids the helper \u001b[0m\u001b[9;1H\u001b[2K         \u001b[2missue entirely.\u001b[0m\u001b[10;1H\u001b[2K  \u001b[2m• Code:\u001b[0m\u001b[11;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[12;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m;; REDUCE done manually — split per line, parse JSON, count\u001b[0m\u001b[13;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def rows\u001b[0m\u001b[14;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m  (->> (:results mapped)\u001b[0m"]
[87.042973, "o", "\u001b[15;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m       (mapcat clojure.string/split-lines)\u001b[0m\u001b[16;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m       (map clojure.string/trim)\u001b[0m\u001b[17;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m       (remove clojure.string/blank?)\u001b[0m\u001b[18;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m       (map parse-json)))\u001b[0m\u001b[19;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[20;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def by-cat (frequencies (map #(get % \"category\") rows)))\u001b[0m\u001b[21;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def by-file (frequencies (map #(get % \"file\") rows)))\u001b[0m\u001b[22;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def noisiest (apply max-key val by-file))\u001b[0m\u001b[23;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[24;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"total ERROR lines:\" (count rows))\u001b[0m\u001b[25;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"=== BY CATEGORY ===\")\u001b[0m\u001b[26;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(pprint (into (sorted-map) by-cat))\u001b[0m\u001b[27;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"=== BY FILE ===\")\u001b[0m\u001b[28;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(pprint (into (sorted-map) by-file))\u001b[0m\u001b[29;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"noisiest file:\" n"]
