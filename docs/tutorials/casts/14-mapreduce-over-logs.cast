[71.168038, "o", " :file field. Then I'll answer. Let me compute it \u001b[0m\u001b[14;1H\u001b[2K         \u001b[2min one clojure fence.\u001b[0m\u001b[15;1H\u001b[2K  \u001b[2m• Code:\u001b[0m\u001b[16;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[17;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m;; REDUCE: parse per-line JSON, count categories, find noisiest file\u001b[0m\u001b[18;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def parsed (rlm$parse-map-results :results (:results mapped) :per-line true))\u001b[0m\u001b[19;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def rows (:parsed parsed))\u001b[0m\u001b[20;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"n-parsed:\" (:n-parsed parsed) \" n-failed:\" (:n-failed parsed))\u001b[0m\u001b[21;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[22;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def cat-counts (rlm$reduce-counts :parsed-results rows :key \"category\"))\u001b[0m\u001b[23;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def file-counts (rlm$reduce-counts :parsed-results rows :key \"file\"))\u001b[0m\u001b[24;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[25;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"=== CATEGORY COUNTS ===\")\u001b[0m\u001b[26;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(pprint (:counts cat-counts))\u001b[0m\u001b[27;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"total:\" "]
