[80.952167, "o", "\u001b[1;1H\u001b[2K         \u001b[2min one clojure fence.\u001b[0m\u001b[2;1H\u001b[2K  \u001b[2m• Code:\u001b[0m\u001b[3;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[4;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m;; REDUCE: parse per-line JSON, count categories, find noisiest file\u001b[0m\u001b[5;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def parsed (rlm$parse-map-results :results (:results mapped) :per-line true))\u001b[0m\u001b[6;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def rows (:parsed parsed))\u001b[0m\u001b[7;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"n-parsed:\" (:n-parsed parsed) \" n-failed:\" (:n-failed parsed))\u001b[0m\u001b[8;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[9;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def cat-counts (rlm$reduce-counts :parsed-results rows :key \"category\"))\u001b[0m\u001b[10;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def file-counts (rlm$reduce-counts :parsed-results rows :key \"file\"))\u001b[0m\u001b[11;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[12;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"=== CATEGORY COUNTS ===\")\u001b[0m\u001b[13;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(pprint (:counts cat-counts))\u001b[0m\u001b[14;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"total:\" (:total cat-counts))\u001b[0m\u001b[15;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(printl"]
[80.952613, "o", "n \"=== PER-FILE COUNTS ===\")\u001b[0m\u001b[16;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(pprint (:counts file-counts))\u001b[0m\u001b[17;1H\u001b[2K    \u001b[2m└─\u001b[0m\u001b[18;1H\u001b[2K  \u001b[2m• Output:\u001b[0m\u001b[19;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[20;1H\u001b[2K    \u001b[2m│ \u001b[0mn-parsed: nil  n-failed: nil\u001b[21;1H\u001b[2K    \u001b[2m│ \u001b[0m=== CATEGORY COUNTS ===\u001b[22;1H\u001b[2K    \u001b[2m│ \u001b[0mnil\u001b[23;1H\u001b[2K    \u001b[2m│ \u001b[0mtotal: nil\u001b[24;1H\u001b[2K    \u001b[2m│ \u001b[0m=== PER-FILE COUNTS ===\u001b[25;1H\u001b[2K    \u001b[2m│ \u001b[0mnil\u001b[26;1H\u001b[2K    \u001b[2m└─\u001b[0m\u001b[27;1H\u001b[2K\u001b[2m[\u001b[0m\u001b[1;96m+\u001b[0m\u001b[2m] \u001b[0m\u001b[1;97mIteration 5 / 100\u001b[0m  \u001b[2m(9.8s)\u001b[0m\u001b[28;1H\u001b[2K\u001b[2m  Think: \u001b[0m\u001b[2mThe reduce helpers returned nil — likely an arg-shape mismatch. The data is tiny, so I'll just do \u001b[0m\u001b[29;1H\u001b[2K         \u001b[2mthe reduce by hand in Clojure: split each result by newline, parse each JSON line, then count by \u001b[0m\u001b[30;1H\u001b[2K         \u001b[2mcategory and by file.\u001b[0m\u001b[31;1H\u001b[2K\u001b[2m[\u001b[0m\u001b[1;93m⠹\u001b[0m\u001b[2m]\u001b[0m \u001b[96mRuminating...\u001b[0m\u001b[2m (1m 11s)\u001b[0m\u001b[32;1H\u001b[2K\u001b[2m────────────────────"]
