[195.503845, "o", "       \u001b[2m(no exec — recommend-only). If load fails, fall back to :ad-hoc with hand-drafted stages. Let me load \u001b[0m\u001b[15;1H\u001b[2K         \u001b[2mthe template and inspect it first, then bootstrap. I'll do the load + inspect in one fence so I can \u001b[0m\u001b[16;1H\u001b[2K         \u001b[2msee acceptance/stages structure before bootstrapping.\u001b[0m\u001b[17;1H\u001b[2K  \u001b[2m• Code:\u001b[0m\u001b[18;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[19;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def tmpl-load (workflow$load-template :id :feature-launch))\u001b[0m\u001b[20;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"LOAD-SOURCE:\" (:source tmpl-load))\u001b[0m\u001b[21;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"LOAD-ERROR:\" (:error tmpl-load))\u001b[0m\u001b[22;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def tmpl (:template tmpl-load))\u001b[0m\u001b[23;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"WF-ID:\" (:workflow/id tmpl))\u001b[0m\u001b[24;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"WF-NAME:\" (:workflow/name tmpl))\u001b[0m\u001b[25;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"ACCEPTANCE:\")\u001b[0m\u001b[26;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(doseq [a (:acceptance tmpl)] (println \"  -\" (:id a) \"|\" (:text a) \"| st"]
[195.503874, "o", "atus:\" (:status a)))\u001b[0m\u001b[27;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"STAGES:\")\u001b[0m\u001b[28;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(doseq [s (:stages tmpl)]\u001b[0m\u001b[29;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m  (println \"  -\" (:id s) \"| agent:\" (or (:recommended-agent s) (:agent s))\u001b[0m\u001b[30;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m           \"| gate-after:\" (:gate-after s) \"| focus:\" (:acceptance-focus s)))\u001b[0m\u001b[31;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(println \"DEFAULTS:\" (:defaults tmpl))\u001b[0m\u001b[32;1H\u001b[2K    \u001b[2m└─\u001b[0m\u001b[33;1H\u001b[2K\u001b[2m[\u001b[0m\u001b[1;93m⠸\u001b[0m\u001b[2m]\u001b[0m \u001b[96mReasoning...\u001b[0m\u001b[2m (3m 7s)\u001b[0m"]
