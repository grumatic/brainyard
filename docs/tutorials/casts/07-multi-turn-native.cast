[378.910793, "o", "\u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m 4                                \u001b[2m │ \u001b[0mKeep \u001b[36mformat_greeting\u001b[0m pure; only \u001b[0m…\u001b[2m │ \u001b[0m\u001b[36msrc/util.py\u001b[0m                        \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m 5                                \u001b[2m │ \u001b[0mValidate: run \u001b[36mgreet World\u001b[0m, \u001b[36mgreet\u001b[0m…\u001b[2m │ \u001b[0m(test)                             \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                            \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97mAcceptance Signals\u001b[0m                                                                                         \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • Flag registered with \u001b[36mstore_true\u001b[0m (\u001b[36mgrep\u001b[0m for \u001b[36madd_argument(\"--verbose\"\u001b[0m in \u001b[36msrc/cli.py\u001b[0m).                     \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • \u001b[36mpython src/cli.py World --verbose 1>/dev/null\u001b[0m prints diagnostics to STDERR; without the flag, STDERR   \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m     is silent.                                   "]
[378.910825, "o", "                                                          \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • \u001b[36mpython src/cli.py World\u001b[0m and \u001b[36mpython src/cli.py World --verbose\u001b[0m produce \u001b[1;97mbyte-identical STDOUT\u001b[0m.           \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m                                                                                                            \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m \u001b[1;97mRisk / Open Question\u001b[0m                                                                                       \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • \u001b[1;97mRisk:\u001b[0m verbose output leaking to STDOUT and polluting machine-readable output → mitigate by writing     \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m     strictly to \u001b[36msys.stderr\u001b[0m.                                                                                \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m   • \u001b[1;97mOpen question:\u001b[0m should \u001b[36mformat_greeting\u001b[0m itself emit diagnostics (requires threading \u001b[36mverbose\u001b[0m into \u001b[36mutil\u001b[0m),  \u001b[92m│\u001b[0m\r\n\u001b[92m│\u001b[0m     or keep all logging in \u001b["]
