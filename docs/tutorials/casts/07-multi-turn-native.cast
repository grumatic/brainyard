[176.378352, "o", "\u001b[1;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36msrc/cli.py\u001b[0m \u001b[2m │ \u001b[0mCLI entry point & argument parsing                                                          \u001b[92m│\u001b[0m\u001b[2;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[36msrc/util.py\u001b[0m\u001b[2m │ \u001b[0mGreeting-formatting helper (leaf)                                                           \u001b[92m│\u001b[0m\u001b[3;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[4;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mWhat Each File Does\u001b[0m                                                                                       \u001b[92m│\u001b[0m\u001b[5;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36mREADME.md\u001b[0m\u001b[0m — Usage doc; shows \u001b[36mpython src/cli.py World\u001b[0m and \u001b[36mpython src/cli.py World --shout\u001b[0m.             \u001b[92m│\u001b[0m\u001b[6;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36msrc/cli.py\u001b[0m\u001b[0m — Executable entry point; builds the arg parser and drives the greeting.                   \u001b[92m│\u001b[0m\u001b[7;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36msrc/util.py\u001b[0m\u001b[0m "]
[176.378383, "o", "— Pure helper that formats the greeting string.                                           \u001b[92m│\u001b[0m\u001b[8;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[9;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mWhat Each Function Does\u001b[0m                                                                                   \u001b[92m│\u001b[0m\u001b[10;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36mbuild_parser()\u001b[0m\u001b[0m (\u001b[36mcli.py\u001b[0m) — Builds an \u001b[36margparse\u001b[0m parser (prog \u001b[36mgreet\u001b[0m); adds positional \u001b[36mname\u001b[0m + optional     \u001b[92m│\u001b[0m\u001b[11;1H\u001b[2K\u001b[92m│\u001b[0m     \u001b[36m--shout\u001b[0m (\u001b[36mstore_true\u001b[0m). Returns the parser.                                                             \u001b[92m│\u001b[0m\u001b[12;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36mmain()\u001b[0m\u001b[0m (\u001b[36mcli.py\u001b[0m) — Parses argv, calls \u001b[36mformat_greeting(args.name, shout=args.shout)\u001b[0m, prints the result. \u001b[92m│\u001b[0m\u001b[13;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36m__main__\u001b[0m guard\u001b[0m (\u001b[36mcli.py\u001b[0m) "]
[176.378392, "o", "— Calls \u001b[36mmain()\u001b[0m when run as a script.                                          \u001b[92m│\u001b[0m\u001b[14;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97m\u001b[36mformat_greeting(name, shout=False)\u001b[0m\u001b[0m (\u001b[36mutil.py\u001b[0m) — Builds \u001b[36mf\"Hello, {name}!\"\u001b[0m; returns \u001b[36m.upper()\u001b[0m when \u001b[36mshout\u001b[0m  \u001b[92m│\u001b[0m\u001b[15;1H\u001b[2K\u001b[92m│\u001b[0m     is truthy, else the plain message.                                                                    \u001b[92m│\u001b[0m\u001b[16;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[17;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[1;97mHow They Fit Together\u001b[0m                                                                                     \u001b[92m│\u001b[0m\u001b[18;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36mREADME.md  ──documents──▶  cli.py\u001b[0m                                                                         \u001b[92m│\u001b[0m\u001b[19;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36mcli.py: main() ──▶ build_parser()      (local, parses argv)\u001b[0m                 "]
[176.378422, "o", "                              \u001b[92m│\u001b[0m\u001b[20;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36m        main() ──▶ format_greeting()   (imported from util.py)\u001b[0m                                            \u001b[92m│\u001b[0m\u001b[21;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[2m\u001b[36mutil.py: format_greeting()             (leaf — no project deps)\u001b[0m                                           \u001b[92m│\u001b[0m\u001b[22;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[1;97mDependency direction:\u001b[0m \u001b[36mcli.py → util.py\u001b[0m                                                                \u001b[92m│\u001b[0m\u001b[23;1H\u001b[2K\u001b[92m│\u001b[0m   • \u001b[36mutil.py\u001b[0m is a leaf with no internal dependencies.                                                      \u001b[92m│\u001b[0m\u001b[24;1H\u001b[2K\u001b[92m│\u001b[0m                                                                                                           \u001b[92m│\u001b[0m\u001b[25;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[3mFull exploration saved at\u001b[0m                                                                                 \u001b[92m│\u001b[0m\u001b[26;1H\u001b[2K\u001b[92m│\u001b[0m \u001b[3m\u001b[36m.brainyard/agents/ex"]
