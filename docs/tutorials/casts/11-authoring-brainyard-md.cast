[135.885353, "o", "\u001b[1;1H\u001b[2K    \u001b[2m│ \u001b[0m===== src/cli.py =====\u001b[2;1H\u001b[2K    \u001b[2m│ \u001b[0m#!/usr/bin/env python3\u001b[3;1H\u001b[2K    \u001b[2m│ \u001b[0m\"\"\"greet — a tiny CLI that prints a greeting.\"\"\"\u001b[4;1H\u001b[2K    \u001b[2m│ \u001b[0mimport argparse\u001b[5;1H\u001b[2K    \u001b[2m│ \u001b[0mfrom util import format_greeting\u001b[6;1H\u001b[2K    \u001b[2m│ \u001b[0mfrom formatters import render\u001b[7;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[8;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[9;1H\u001b[2K    \u001b[2m│ \u001b[0mdef build_parser():\u001b[10;1H\u001b[2K    \u001b[2m│ \u001b[0m    p = argparse.ArgumentParser(prog=\"greet\", description=\"Print a greeting.\")\u001b[11;1H\u001b[2K    \u001b[2m│ \u001b[0m    p.add_argument(\"name\", help=\"who to greet\")\u001b[12;1H\u001b[2K    \u001b[2m│ \u001b[0m    p.add_argument(\"--shout\", action=\"store_true\", help=\"upper-case the greeting\")\u001b[13;1H\u001b[2K    \u001b[2m│ \u001b[0m    return p\u001b[14;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[15;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[16;1H\u001b[2K    \u001b[2m│ \u001b[0mdef main():\u001b[17;1H\u001b[2K    \u001b[2m│ \u001b[0m    args = build_parser().parse_args()\u001b[18;1H\u001b[2K    \u001b[2m│ \u001b[0m    print(render(format_greeting(args.name, shout=args.shout)))\u001b[19;1H\u001b[2K    \u001b[2m│ \u001b[0m"]
