[57.451388, "o", "\u001b[27;1H\r\n\u001b[27;1H\r\n\u001b[92m┌────────────────────────────────────────────────────────────────────────────────────────────────┐\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mUser-Defined Agents (this project)\u001b[0m                                                             \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mNone.\u001b[0m \u001b[36mmeta-agent$list\u001b[0m returns an empty set — no persistent agents have been authored under     \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36m<project>/.brainyard/agents/user$agent/\u001b[0m yet. If you'd like one, I can author it (instruction + \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m tool-context, validated and verified).                                                         \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m"]
[57.451399, "o", "│\u001b[0m                                                                                                \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mBuilt-In Specialists (22 registered)\u001b[0m                                                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m                                                                                                \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[1;97mAgent\u001b[0m         \u001b[2m │ \u001b[0m\u001b[1;97mRole\u001b[0m                                                                          \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[2m───────────────┼────────────────────────────────────────────────────────────\u001b[0m                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mmain-agent\u001b[0m    \u001b[2m │ \u001b[0mFront-door router → picks the right specialist per question                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mcoact-agent\u001b[0m"]
[57.451462, "o", "   \u001b[2m │ \u001b[0mReasoning + Code + Action loop (3 channels)                                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mreact-agent\u001b[0m   \u001b[2m │ \u001b[0mReAct — one LLM call per iteration                                            \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mresearch-agent\u001b[0m\u001b[2m │ \u001b[0mMulti-specialist research loop with durable dossier                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mworkflow-agent\u001b[0m\u001b[2m │ \u001b[0mDomain multi-stage workflow loop (templated stages)                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mexplore-agent\u001b[0m \u001b[2m │ \u001b[0mRead-mostly exploration (filesystem / web / MCP / skills)                     \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mplan-agent\u001b[0m    \u001b[2m │ \u001b[0mAuthor plan blueprints with pre/post-flight grading                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mtodo-agent\u001b[0m    \u001b[2m │ \u001b[0mAuthor/advance executable todos with gating                                   \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36me"]
[57.451487, "o", "xec-agent\u001b[0m    \u001b[2m │ \u001b[0mDrive a todo list to completion, tag-based routing                            \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36meval-agent\u001b[0m    \u001b[2m │ \u001b[0mScore executed todos against plan acceptance criteria                         \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mupdate-agent\u001b[0m  \u001b[2m │ \u001b[0mSafe single-file edits (probe→apply→verify→rollback)                          \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mdebug-agent\u001b[0m   \u001b[2m │ \u001b[0mLive-runtime nREPL debug loop against the running JVM                         \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mmemory-agent\u001b[0m  \u001b[2m │ \u001b[0mSteward of the layered memory stack                                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36minit-agent\u001b[0m    \u001b[2m │ \u001b[0mAuthor/maintain BRAINYARD.md (project + user scope)                           \u001b[92m│\u001b[0m\u001b[27;1H\r\n\u001b[92m│\u001b[0m \u001b[36mconfig-agent\u001b[0m  \u001b[2m │ \u001b[0mConversational hub for \u001b[36m~/.brainyard/config.edn\u001b[0m                                \u001b[92m│\u001b[0m\u001b"]
