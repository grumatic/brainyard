[65.597262, "o", "\u001b[1;1H\u001b[2K         \u001b[2msandbox for the PERSIST phase.\u001b[0m\u001b[2;1H\u001b[2K  \u001b[2m• Code:\u001b[0m\u001b[3;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[4;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def pre {:verdict :go\u001b[0m\u001b[5;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :checks {:c1 :pass :c2 :pass :c3 :pass :c4 :not-evaluated\u001b[0m\u001b[6;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m                   :c5 :pass :c6 :pass :c7 :informational}\u001b[0m\u001b[7;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :exploration-path nil\u001b[0m\u001b[8;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :owner :unknown\u001b[0m\u001b[9;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :related-plans []\u001b[0m\u001b[10;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :gather-question nil\u001b[0m\u001b[11;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m          :refuse-reason nil})\u001b[0m\u001b[12;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m\u001b[0m\u001b[13;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m(def body\u001b[0m\u001b[14;1H\u001b[2K    \u001b[2m│ \u001b[0m\u001b[35m    \u001b[2m│ \u001b[0m\u001b[35m[*Block:ikq91d0code* collapsed: +37 lines | Enter: expand, Ctrl-O: edit]\u001b[0m\u001b[0m\u001b[15;1H\u001b[2K    \u001b[2m└─\u001b[0m\u001b[16;1H\u001b[2K  \u001b[2m• Output:\u001b[0m\u001b[17;1H\u001b[2K    \u001b[2m┌─\u001b[0m\u001b[18;1H\u001b[2K    \u001b[2m│ \u001b[0m{:error"]
