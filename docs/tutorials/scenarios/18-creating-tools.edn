;; docs/tutorials/scenarios/18-creating-tools.edn
;;
;; Walks the tool-agent through the user-defined-tool lifecycle: discover ->
;; author -> verify/use. Recorded live against claude-code/opus via the bb tui
;; JVM launch mode (the BY_SESSION_ID env hook ships in source).
;;
;; NOTE: chapter 2 writes a real persistent tool to <project>/.brainyard/tools/
;; (registered as `user$tool$count-words`). The demo tool is removed after recording
;; (see the recorder notes) so it isn't committed.
{:id          "18-creating-tools"
 :title       "Authoring a persistent tool with the tool-agent"
 :description "The tool-agent lists user-defined tools, authors a new persistent
               tool from a plain-English request, then reads it back and runs
               it — recorded live against claude-code/opus."

 :walkthrough
 "The tool-agent walks the full user-defined-tool lifecycle across three turns.

  **Turn 1 — discover.** Lists the persistent tools already registered for the
  project (the `user$tool$` namespace under `<project>/.brainyard/tools/`).

  **Turn 2 — author.** From a plain-English request, it authors a new
  `count-words` tool — a `(fn [args] …)` body plus a Malli `:input-schema`,
  persisted to `<project>/.brainyard/tools/count-words.edn` and registered as
  `user$tool$count-words` (callable directly as a first-class tool on the next turn).

  **Turn 3 — verify & use.** Reads the tool definition it just wrote back, then
  invokes `user$tool$count-words` on a real file to show it working end-to-end. (The
  demo tool is removed after recording so it isn't committed.)"

 :terminal    {:cols 100 :rows 32 :title "brainyard tutorial — creating tools"}
 :idle-time-limit 2.5
 :startup-timeout-secs 120

 :launch
 {:binary "bb tui"
  :args   ["-a" "tool-agent" "-p" "claude-code" "-m" "opus" "--new"]
  :env    {"BY_TUTORIAL_MODE" "1"
           "BY_SESSION_ID"     "tutorial-18-tools"}}

 :preamble
 [{:type :narrate :text "# tool-agent: discover, author, and run a persistent tool" :pause-ms 2000}]

 :chapters
 [{:id    :ch1
   :label "Discover — list user-defined tools"
   :prompt "List the user-defined tools currently registered in this project."
   :expect {:contains ["tool"]}
   :settle {:timeout-secs 180}}

  {:id    :ch2
   :label "Author — create a persistent tool"
   :prompt "Create a new persistent tool named count-words that takes a file path and returns the number of whitespace-separated words in that file's content."
   :expect {:contains ["count-words"]}
   :settle {:timeout-secs 240}}

  {:id    :ch3
   :label "Verify & use — read it back, then run it"
   :prompt "Read back the count-words tool you just created, then run it on docs/tutorials/README.md and report the word count."
   :expect {:contains ["count-words"]}
   :settle {:timeout-secs 240}}]

 :postamble
 [{:type :keys :send "/quit" :pause-ms 500}
  {:type :keys :send "C-m"   :pause-ms 1000}]}
