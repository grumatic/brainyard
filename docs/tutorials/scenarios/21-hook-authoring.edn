;; docs/tutorials/scenarios/21-hook-authoring.edn
;;
;; Walks the hook-agent through the user-defined-hook lifecycle: discover ->
;; author -> verify. Recorded live against claude-code/opus via the bb tui JVM
;; launch mode (so the hook-agent ships from source).
;;
;; NOTE: chapter 2 writes a real persistent hook to <project>/.brainyard/hooks/
;; (registered as `:user-hook/audit-bash` on :agent.tool-use/post). The demo
;; hook is removed after recording (see the recorder notes) so it isn't
;; committed and doesn't fire on later sessions.
{:id          "21-hook-authoring"
 :title       "Authoring a persistent hook with the hook-agent"
 :description "The hook-agent lists the runtime events you can hook, authors a
               new persistent observer hook from a plain-English request, then
               reads it back to confirm it is registered — recorded live against
               claude-code/opus."

 :walkthrough
 "The hook-agent walks the full user-defined-hook lifecycle across three turns.
  A hook is an OBSERVER: it fires on a pre-defined Brainyard runtime event and
  runs a side effect (it cannot block or rewrite agent behavior in v1).

  **Turn 1 — discover.** Lists the runtime events a hook may target (via
  `hooks$events`) — each with the payload its handler receives and whether it is
  gated — plus any hooks already registered for the project.

  **Turn 2 — author.** From a plain-English request, it authors a new
  `audit-bash` hook — a `(fn [event] …)` body scoped with `{:tool-name \"bash\"}`
  to the `:agent.tool-use/post` event. It dry-runs the draft with
  `hooks$validate`, then `hooks$create` persists the source to
  `<project>/.brainyard/hooks/audit-bash.edn` and registers it as
  `:user-hook/audit-bash` (firing on the very next matching bash call). The body
  composes the tool palette by direct symbol — `(write-file {…})` — to append
  each command to `.brainyard/audit.log`.

  **Turn 3 — verify.** Reads the hook definition it just wrote back and confirms
  it is registered and active. (The demo hook is removed after recording so it
  isn't committed.)"

 :terminal    {:cols 100 :rows 32 :title "brainyard tutorial — authoring a hook"}
 :idle-time-limit 2.5
 :startup-timeout-secs 120

 :launch
 {:binary "bb tui"
  :args   ["-a" "hook-agent" "-p" "claude-code" "-m" "opus" "--new"]
  :env    {"BY_TUTORIAL_MODE" "1"
           "BY_SESSION_ID"     "tutorial-21-hooks"}}

 :preamble
 [{:type :narrate :text "# hook-agent: discover events, author a hook, and verify it" :pause-ms 2000}]

 :chapters
 [{:id    :ch1
   :label "Discover — list hookable events"
   :prompt "What runtime events can I hook, and are any hooks already registered in this project?"
   :expect {:contains ["event"]}
   :settle {:timeout-secs 180}}

  {:id    :ch2
   :label "Author — create a persistent hook"
   :prompt "Create a persistent hook named audit-bash that fires after every bash tool call (the agent.tool-use/post event, scoped to the bash tool) and appends the command to .brainyard/audit.log. Validate it first, then create it."
   :expect {:contains ["audit-bash"]}
   :settle {:timeout-secs 240}}

  {:id    :ch3
   :label "Verify — read it back and confirm it is registered"
   :prompt "Read back the audit-bash hook you just created and confirm it is registered and active."
   :expect {:contains ["audit-bash"]}
   :settle {:timeout-secs 240}}]

 :postamble
 [{:type :keys :send "/quit" :pause-ms 500}
  {:type :keys :send "C-m"   :pause-ms 1000}]}
