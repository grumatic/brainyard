{:workflow/id   :doc-update
 :workflow/name "Documentation Update Workflow"
 :workflow/description
 "Update existing documentation: scope the change → draft prose → verify
  examples → review-gate → publish (commit / merge). Lighter than
  feature-launch — no implementation stage, no announcement by default."

 :acceptance
 [{:id :a1 :text "Doc changes match the user's stated intent"}
  {:id :a2 :text "Prose is clear and consistent with existing style"}
  {:id :a3 :text "Any code examples / commands are verified accurate"}
  {:id :a4 :text "Changes committed (and merged if PR-bound)"}]

 :stages
 [{:id                :scope
   :purpose           "Clarify which files / sections change and confirm the requested intent."
   :recommended-agent :research-agent
   :acceptance-focus  [:a1]}

  {:id                :draft
   :purpose           "Author the prose changes via update-agent (or exec-agent for multi-file edits)."
   :recommended-agent :update-agent
   :acceptance-focus  [:a1 :a2]}

  {:id                :verify-examples
   :purpose           "Run / spot-check any code, shell, or CLI examples in the new prose."
   :recommended-agent :exec-agent
   :acceptance-focus  [:a3]}

  {:id                :review
   :purpose           "Surface the diff for human review before committing."
   :recommended-agent :coact-agent
   :gate-after        :user
   :acceptance-focus  [:a1 :a2 :a3]}

  {:id                :publish
   :purpose           "Commit the changes (and open a PR when the repo workflow requires one)."
   :recommended-agent :exec-agent
   :acceptance-focus  [:a4]}]

 :defaults
 {:hitl               :gates
  :max-stage-attempts 2
  :sub-lm             "claude-haiku-4-5-20251001"}}
