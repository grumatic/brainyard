# Brainyard (`by`) environment template.
#
# Copy to `.env` and fill in the providers you use:  cp .env.example .env
# The `by` wrapper sources a nearby `.env` automatically (disable with
# BY_NO_DOTENV=1, or point elsewhere with BY_ENV_FILE=/path/to/.env).
# `.env` is gitignored — never commit real secrets. This template is safe to commit.
#
# You only need credentials for the providers you actually use. Some providers
# need no key at all:
#   claude-code  — drives the local Claude CLI (default; no API key)
#   ollama       — local models (no key)
#   apple-fm     — on-device Apple Foundation Models, macOS 26+ (no key)

# ── Identity ─────────────────────────────────────────────────────────────────
# User id stamped onto sessions and memory (L1/L2/L3 are partitioned by it).
# Resolved once at startup, in precedence order:
#   --user-id / -u CLI flag  >  BY_USER_ID  >  `user.name` system property (OS
#   login name)  >  "by-user". Set this to pin a stable identity across machines
# or logins, or to share one memory store between accounts. Leave unset to
# default to your OS login name.
# BY_USER_ID=

# ── Working directory ────────────────────────────────────────────────────────
# Effective working directory for tools/agents. This does NOT chdir the JVM —
# it is threaded through config and applied to file tools + spawned subprocesses.
# Resolved once at startup, in precedence order:
#   --working-dir / -C CLI flag  >  BY_WORKING_DIR  >  process cwd (user.dir).
# The flag is strict (a non-directory path exits 1); a bad BY_WORKING_DIR here
# silently falls back to the process cwd.
# BY_WORKING_DIR=
#
# Explicit project root override (where .brainyard/ artifacts live). When unset,
# project-dir is the git-root walking up from the working dir, else the working
# dir itself.
# BY_PROJECT_DIR=

# ── LLM provider API keys ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# Other OpenAI-compatible providers (optional)
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
AZURE_OPENAI_API_KEY=

# Free / self-hosted OpenAI-compatible endpoint (provider :free-llm).
# Point FREELLM_BASE_URL at any OpenAI-compatible /v1 base; FREELLM_API_KEY is
# optional (sent as a Bearer token when set). Use as: by ask -p free-llm -m auto '…'
FREELLM_BASE_URL=
FREELLM_API_KEY=

# ── AWS / Bedrock ────────────────────────────────────────────────────────────
# Bedrock uses the standard AWS credential chain. Easiest: a named profile.
# NOTE: the binary honors AWS_PROFILE but NOT AWS_DEFAULT_PROFILE.
AWS_PROFILE=
AWS_REGION=us-east-1

# Alternatively, static keys instead of a profile (leave AWS_PROFILE empty):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ── GitHub CLI (gh) ──────────────────────────────────────────────────────────
# The `gh` CLI reads its token from the environment. Set ONE of these (GH_TOKEN
# wins) to a personal access token with the scopes you need (e.g. repo). Left
# commented so a copied `.env` doesn't export an empty token.
# GH_TOKEN=
# GITHUB_TOKEN=

# ── Google Workspace MCP (gmail / google-calendar) ───────────────────────────
# The gmail and google-calendar seed MCP servers bridge to Google's official
# hosted MCP endpoints via mcp-remote, which needs a PRE-REGISTERED OAuth client
# (Google does not support dynamic registration). Create an OAuth client ID in
# the Google Cloud console and set both below; first `/mcp gmail start` (or
# google-calendar) opens a browser consent flow. Leave empty if unused.
GCP_OAUTH_CLIENT_ID=
GCP_OAUTH_CLIENT_SECRET=

# ── Web sharing (by --web, via ttyd) ─────────────────────────────────────────
# Share a TUI session in the browser. Requires `ttyd` on PATH (--web-tmux also
# needs `tmux`). Defaults here are overridden by the matching --web* CLI flags.
# Auth is ALWAYS required (password auto-generated if unset); bind defaults to
# localhost. See docs/web-sharing.md. SECURITY: a writable session is a shell
# into an agent that can run code — prefer an SSH tunnel over binding 0.0.0.0.
# BY_WEB=1                 # enable web sharing without passing --web
# BY_WEB_TMUX=1            # Tier 2: private tmux session; launching terminal stays a dashboard
# BY_WEB_PORT=7681         # listen port (0 = random)
# BY_WEB_BIND=127.0.0.1    # bind address (127.0.0.1 = localhost only)
# BY_WEB_USER=by           # basic-auth username
# BY_WEB_PASS=             # basic-auth password (auto-generated if empty)
# BY_WEB_READONLY=1        # clients may watch but not type
# BY_WEB_MAX_CLIENTS=0     # max simultaneous clients (0 = unlimited)
# BY_WEB_ONCE=1            # stop after the first client disconnects

# ── SCI code-eval interop (:sandbox-interop) ─────────────────────────────────
# Controls Java interop in the in-process SCI sandbox where agent-written
# Clojure runs. Default `restricted` denies System/Runtime/ProcessBuilder/etc.
# `full` permits arbitrary Java interop — ONLY safe inside a disposable
# container; do NOT use on a workstation. `auto` = full when a container
# (Docker/devcontainer) is detected, else restricted. Seeds the schema default;
# `.brainyard/config.edn` {:agent {:config {:sandbox-interop …}}} overrides it.
# See docs/sandboxing.md. Native binary: full interop is bounded by the
# reflection config; complete only under BY_JAR=1.
# BY_SANDBOX_INTEROP=restricted   # restricted | full | auto

# ── Prompt-cache TTL for stable prompt zones ──────────────────────────────────
# "1h" keeps the cross-turn prompt-cache prefix (static agent core +
# session-stable zones) alive across human-paced turn gaps — the 5m default
# expires between turns whenever you think for more than five minutes.
# Applies to anthropic / anthropic-max (extended-cache-ttl beta header),
# bedrock (Converse cachePoint ttl — Anthropic Claude models), and openai
# (prompt_cache_retention "24h" — extended retention at no extra cost; already
# the server default for non-ZDR orgs). Cost on Anthropic-format providers:
# cache writes on the long-TTL zones bill at 2x base input, paid roughly once
# per session — recouped by a single cross-turn cache hit. See
# docs/design/prompt-cache-arrangement.md (Phase 4).
# BY_CACHE_TTL=1h                 # 5m (default) | 1h

# ── TUI display detail (display-format) ───────────────────────────────────────
# Source of truth for the TUI's display verbosity — the /display-format command
# and the -v flag both resolve through this config key. quiet = think bullets +
# box-less answer; normal = iterations + tools + answer; verbose = + BT traces.
# Seeds the schema default; `.brainyard/config.edn` {:agent {:config
# {:display-format …}}} and the /display-format command override it.
# BY_DISPLAY_FORMAT=normal        # quiet | normal | verbose

# ── OAuth token storage (clj-oauth) ──────────────────────────────────────────
# Where OAuth tokens (MCP servers + Anthropic) are stored. `auto` (default)
# uses the OS keychain when its CLI is present and a probe round-trips (macOS
# `security`, Linux `secret-tool`), else the file fallback. `keychain` forces
# the keychain (falling back to file if no CLI). `file` always uses the file
# store at ~/.brainyard/oauth/<user-id>/<account>.json (0600). The playground
# container has no keychain daemon, so it lands on `file`. See docs/design/oauth.md.
# BY_OAUTH_TOKEN_STORE=auto       # auto | keychain | file

# ── Hermes-comparison feature flags (R1–R4) ──────────────────────────────────
# Opt-in capabilities from docs/design/hermes-comparison.md. All default OFF
# (or :local); uncomment + set to enable. See that doc and
# docs/design/self-improve-design.md.
#
# Self-improvement loop (R1): autonomously distil/refine SKILL.md *proposals* and
# nudge you to review them. Proposals stage under .brainyard/skills/proposals/
# and only go live when you accept (skill-proposal$accept) — nothing auto-writes.
# BY_ENABLE_SKILL_DISTILLATION=true   # score finished turns; stage a skill proposal past the threshold
# BY_SKILL_DISTILL_THRESHOLD=0.7      # 0.0..1.0 reusability score required to stage
# BY_ENABLE_SKILL_REFINEMENT=true     # on a failed skill$ run, stage a SKILL.md revision proposal
# BY_ENABLE_SELF_IMPROVE_NUDGES=true  # surface pending proposals in the iteration block + to the LLM
#
# Scheduler (R2): an in-process daemon ticker runs cron/fire-at jobs while a
# session is open (schedule$add/list/run-due). Runs LLM jobs unattended → opt-in.
# BY_ENABLE_SCHEDULER=true            # start the ticker
# BY_SCHEDULER_TICK_MS=60000          # ticker interval ms (lower = finer cron resolution)
#
# Messaging gateway (R3): reach the agent from Telegram. gateway$start long-polls;
# gateway$pair-code mints a one-time code a remote user sends to the bot to pair.
# BY_TELEGRAM_TOKEN=123456:AA...      # bot token from @BotFather (secret — keep out of git)
# BY_GATEWAY_PAIR_CODE_TTL_MS=600000  # pairing-code lifetime (ms)
#
# Execution backend (R4): WHERE shell + Clojure run. :local (default) = this
# machine. Point :nrepl-host at a remote nREPL server to run the :clj-backend
# :nrepl Clojure off-laptop (full-trust — your own server only).
# BY_EXEC_BACKEND=local               # local (Docker/SSH backends pending)
# BY_NREPL_HOST=127.0.0.1             # nREPL endpoint host for the :nrepl Clojure backend
#
# Context-graph memory (CR-MEM-20..24): a typed entity/relationship graph +
# vector index layered over the L1/L2/L3 store as extra recall signals. Off by
# default; non-regressing (empty graph => recall == FTS). See
# docs/design/context-graph-memory-design.md.
# BY_ENABLE_GRAPH_MEMORY=true         # turn the overlay on (default false)
# BY_GRAPH_EMBED_MODEL=static         # semantic embedder: "static" = self-contained
#                                     # in-binary Model2Vec (256-dim, no server); or a
#                                     # provider/model on an OpenAI-compatible /embeddings
#                                     # endpoint, e.g. ollama/nomic-embed-text (768-dim,
#                                     # local) or openai/text-embedding-3-small. Unset =>
#                                     # no vector signal. NOT bedrock/anthropic (no embeddings).
# BY_GRAPH_EXTRACT_MODEL=bedrock/amazon.nova-lite-v1:0  # chat LM that extracts entities/
#                                     # relationships + writes community summaries. Unset =>
#                                     # graph stays storage-only (no self-population).
# BY_GRAPH_EMBED_DIMS=768             # graph_vec vector dim; must match the embed model
#                                     # (static auto-sets 256). Changing the embed model
#                                     # pauses vector recall until `memory$reembed`.
# BY_SQLITE_VEC_PATH=/path/to/vec0    # override the bundled sqlite-vec extension location
# BY_MODEL2VEC_PATH=/path/to/model    # override the bundled Model2Vec model dir
#
# Surface background memory milestones (L2->L3 consolidation, graph extraction)
# in the TUI as muted "memory - ..." lines, so you can see memory working. On by
# default; toggleable live. Set false to keep memory activity silent (still logged).
# BY_SHOW_MEMORY_ACTIVITY=false       # silence the memory-activity lines (default true)
