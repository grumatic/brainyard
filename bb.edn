  test
  {:doc "Run all Polylith tests"
   :task (shell "clj" "-M:poly" "test")}

  test:memory
  {:doc "End-to-end memory-recall harness (real LLM) — session-scoped L1/L2.

   Drives `by ask` over multiple one-shot turns sharing a pinned --session/-u,
   then verifies (a) facts were captured to the SQLite episodes store and
   (b) a fresh process recalls them via session-scoped L2 recall. Uses a
   throwaway user-id + db (cleaned up on exit); needs jq + sqlite3 and a
   working provider (default claude-code:haiku).

   Usage: bb test:memory          (or: BY_BIN=…/target/by bb test:memory)"
   :task (apply shell "bash" "scripts/test-memory-recall.sh" *command-line-args*)}

  test:memory:l3
  {:doc "Cross-session L3 memory harness (real LLM) — heuristic consolidation.

   States facts in session A, runs `by memory consolidate` (deterministic
   heuristic L2→L3 reducer), then verifies a DIFFERENT session recalls them —
   which is only possible via cross-session L3 semantic facts. Needs jq +
   sqlite3 and a working provider.

   Usage: bb test:memory:l3"
   :task (apply shell "bash" "scripts/test-memory-l3-recall.sh" *command-line-args*)}

  test:memory:l3-graph
  {:doc "Cross-session L3 memory harness (real LLM) — graph-community tier.

   Full context-graph pipeline: state facts → `by memory graph-build`
   (sync entity/relation extraction) → `consolidate --reducer community`
   (community summaries → L3) → cross-session recall. Requires the graph tier
   (BY_ENABLE_GRAPH_MEMORY + an extract model; default claude-code:haiku) and
   is slower/LLM-dependent. Needs jq + sqlite3.

   Usage: bb test:memory:l3-graph   (or: EXTRACT_MODEL=… bb test:memory:l3-graph)"
   :task (apply shell "bash" "scripts/test-memory-l3-graph.sh" *command-line-args*)}

  oauth:test-server
  {:doc "Run the Brainyard test OAuth + MCP device-flow provider (test/demo only).

   A real RFC 8628 device-flow authorization server + an OAuth-gated MCP
   endpoint, so you can exercise the clj-oauth + MCP stack end to end (Anthropic
   consumer OAuth is Claude-Code-only and can't serve as a target). Prints a
   ready-to-paste `:mcp :servers` config; then `/mcp brainyard auth` in the TUI
   shows a device code box you approve in a browser. Test-only — never shipped.

   Usage: bb oauth:test-server [port]   (default 7900)"
   :task (let [port (or (first *command-line-args*) "7900")]
           (shell {:dir "components/clj-oauth"}
                  "clj" "-M:test" "-m" "ai.brainyard.clj-oauth.test-server" port))}

  test:component
  {:doc "Test a specific component: bb test:component <name>

   Discovers every `*_test.clj` namespace under components/<name>/test/ and
   runs them with clojure.test via `clj -M:test` in the component dir
   (the workspace has no standalone test-runner; poly is the only other
   path). Exits non-zero on any failure/error."
   :requires ([babashka.fs :as fs]
              [clojure.string :as str])
   :task (let [component (first *command-line-args*)
               dir (str "components/" component)
               test-dir (str dir "/test")]
           (when-not component
             (println "Usage: bb test:component <name>")
             (System/exit 1))
           (when-not (fs/exists? dir)
             (println (str "Component not found: " dir))
             (System/exit 1))
           (let [nses (->> (when (fs/exists? test-dir)
                             (fs/glob test-dir "**/*_test.clj"))
                           (map (fn [p]
                                  (let [rel    (str (fs/relativize test-dir p))
                                        no-ext (subs rel 0 (- (count rel) 4))]
                                    (-> no-ext
                                        (str/replace "/" ".")
                                        (str/replace "_" "-")))))
                           sort)
                 nses-str (str/join " " (map (fn [n] (str "'" n)) nses))]
             (if (empty? nses)
               (do (println (str "No *_test.clj namespaces under " test-dir))
                   (System/exit 1))
               (let [eform (str "(require " nses-str ")"
                                "(require 'clojure.test)"
                                "(let [m (clojure.test/run-tests " nses-str ")]"
                                "  (shutdown-agents)"
                                "  (System/exit (if (zero? (+ (:fail m) (:error m))) 0 1)))")]
                 (shell {:dir dir} "clj" "-M:test" "-e" eform)))))}

