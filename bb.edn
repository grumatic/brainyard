  ;; --------------- Migrations ---------------
  migrate:plan-agent
  {:doc "One-shot copy of legacy `.brainyard/plans/*.md` into the new
   `.brainyard/agents/plan-agent/plans/` location. Source files are NOT deleted —
   a `git checkout` rolls back instantly. Slug-level collisions are
   reported and skipped (the new file wins).

   Usage: bb migrate:plan-agent
          bb migrate:plan-agent --dry-run    # report only, no copies"
   :requires ([babashka.fs :as fs]
              [clojure.string :as str])
   :task (let [args      (set *command-line-args*)
               dry-run?  (contains? args "--dry-run")
               root      (System/getProperty "user.dir")
               legacy    (fs/path root ".brainyard/plans")
               new-dir   (fs/path root ".brainyard/agents/plan-agent/plans")]
           (cond
             (not (fs/exists? legacy))
             (println "Nothing to migrate — no .brainyard/plans/ directory at" (str legacy))

             :else
             (do
               (when-not dry-run? (fs/create-dirs new-dir))
               (let [files   (->> (fs/list-dir legacy)
                                  (filter (fn [p] (str/ends-with? (str p) ".md")))
                                  vec)
                     results (reduce
                              (fn [acc src]
                                (let [name    (.toString (fs/file-name src))
                                      dest    (fs/path new-dir name)
                                      exists? (fs/exists? dest)]
                                  (cond
                                    exists?
                                    (do (println (str "  SKIP  " name " — already at new path"))
                                        (update acc :skipped inc))

                                    dry-run?
                                    (do (println (str "  PLAN  " name))
                                        (update acc :would-move inc))

                                    :else
                                    (try
                                      (fs/copy src dest {:replace-existing false})
                                      (println (str "  MOVE  " name))
                                      (update acc :moved inc)
                                      (catch Exception e
                                        (println (str "  FAIL  " name " — " (.getMessage e)))
                                        (update acc :failed inc))))))
                              {:moved 0 :skipped 0 :failed 0 :would-move 0}
                              files)]
                 (println)
                 (println "Summary:")
                 (println (str "  total candidates: " (count files)))
                 (when-not dry-run?
                   (println (str "  moved:    " (:moved results)))
                   (println (str "  skipped:  " (:skipped results) " (already at new path)"))
                   (println (str "  failed:   " (:failed results))))
                 (when dry-run?
                   (println (str "  would-move: " (:would-move results)))
                   (println (str "  skipped:    " (:skipped results))))
                 (println)
                 (println (str "Source files preserved at " (str legacy) " — `git checkout` rolls back."))))))}

