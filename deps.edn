{:mvn/repos {"my.datomic.com" {:url "https://my.datomic.com/repo"}
             "vendredi" {:url "https://repository.hellonico.info/repository/hellonico/"}}
 :aliases
 {:dev
  {:extra-paths ["development/src"]
   :extra-deps {org.clojure/clojure {:mvn/version "1.12.0"}
                ;; Components — the agent-tui-app brick closure mirrored in this repo
                ai.brainyard/util              {:local/root "components/util"}
                ai.brainyard/mulog             {:local/root "components/mulog"}
                ai.brainyard/clj-http-native   {:local/root "components/clj-http-native"}
                ai.brainyard/clj-llm           {:local/root "components/clj-llm"}
                ai.brainyard/behavior-tree     {:local/root "components/behavior-tree"}
                ai.brainyard/memory            {:local/root "components/memory"}
                ai.brainyard/clj-sandbox       {:local/root "components/clj-sandbox"}
                ai.brainyard/clj-nrepl         {:local/root "components/clj-nrepl"}
                ai.brainyard/display-block     {:local/root "components/display-block"}
                ai.brainyard/analytics         {:local/root "components/analytics"}
                ai.brainyard/env-detect        {:local/root "components/env-detect"}
                ai.brainyard/aws-client        {:local/root "components/aws-client"}
                ai.brainyard/agent             {:local/root "components/agent"}
                ai.brainyard/agent-tui-persist {:local/root "components/agent-tui-persist"}
                ai.brainyard/agent-tui-tmux    {:local/root "components/agent-tui-tmux"}
                ai.brainyard/acp               {:local/root "components/acp"}
                ai.brainyard/acp-client        {:local/root "components/acp-client"}
                ;; Bases
                ai.brainyard/agent-tui         {:local/root "bases/agent-tui"}
                ai.brainyard/acp-stub-agent    {:local/root "bases/acp-stub-agent"}}}

  :test
  {:extra-paths []}

  :repl
  {:extra-deps {nrepl/nrepl {:mvn/version "1.3.0"}
                cider/cider-nrepl {:mvn/version "0.57.0"}}
   :main-opts ["-m" "nrepl.cmdline"
               "--middleware" "[cider.nrepl/cider-middleware]"]}

  :poly
  {:extra-deps {polylith/clj-poly {:mvn/version "0.2.21"}}
   :main-opts ["-m" "polylith.clj.core.poly-cli.core"]}}}
