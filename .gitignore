# Clojure / tools.deps
.cpcache/
.clj-kondo/.cache/
.nrepl-port
.shadow-cljs/
.lsp/
.calva/

# Build outputs
target/
classes/
*.jar
!docs/**/*.jar

# Version stamp — generated by `bb version:ata` from `git describe` at build time.
# Tracking it would dirty the tree on every build and break the release purity gate.
**/resources/build-version.edn

# Local env — never commit
.env
.env.*
!.env.example

# Node
node_modules/

# Editor scratch
*~
.#*
*.bak
*.swp
*.swo
.DS_Store
.idea/
.vscode/
*.iml

# Runtime log — Timbre writes app.log to whatever cwd a run starts from
# (repo root for `bb test`, a brick dir for brick-local runs).
app.log

# Agent / tooling local state (never publish)
.claude/
.omc/
.brainyard/

# Release staging — built artifacts, uploaded to GitHub Releases, not git
release/

# Transient — regenerated from CHANGELOG.md for each release as the release-body source
CHANGELOG-latest.md

# Benchmark outputs — never publish
benchmark-results/

# Generated self-contained tutorials page (~15MB) — published via GitHub Pages
# (gh-pages branch), regenerated with `bb tutorial:output`. Not tracked on main.
docs/tutorials/output/
