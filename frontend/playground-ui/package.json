{
  "name": "playground-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Brainyard Playground front-end — ClojureScript + Replicant SPA",
  "scripts": {
    "watch": "shadow-cljs watch app",
    "release": "shadow-cljs release app && cp resources/public/index.html ../../bases/playground-server/resources/public/index.html",
    "clean": "rm -rf resources/public/js .shadow-cljs"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.20"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  }
}
